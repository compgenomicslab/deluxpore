executor {
    name = 'slurm'
    queueSize = 50
}

process {
    executor = 'slurm'
    
    // Global retry strategy for OOM errors
    errorStrategy = { task.exitStatus in [137, 140] ? 'retry' : 'finish' }
    maxRetries = 3

    withLabel: 'fast' { 
        cpus = 1
        memory = { 10.GB * Math.pow(2, task.attempt - 1) }  // 10GB → 20GB → 40GB
        queue = { task.attempt > 1 ? 'medium' : 'fast' }
        time = { 2.hour * task.attempt }
    }

    withLabel: 'medium' { 
        cpus = 1
        memory = { 50.GB * Math.pow(2, task.attempt - 1) }  // 50GB → 100GB
        queue = 'medium'
        time = { 8.hour * task.attempt }
    }

    withLabel: 'filter_trim' { 
        cpus = 6
        memory = { 10.GB * Math.pow(2, task.attempt - 1) }
        queue = { task.attempt > 1 ? 'medium' : 'fast' }
        time = { 2.hour * task.attempt }
        maxForks = 50
    }

    withName: 'mapReads2DB' { 
        cpus = 8
        memory = { 20.GB * Math.pow(2, task.attempt - 1) }
        queue = 'medium'
        time = '1 day'
        maxForks = 8
    }
    
    withName: 'calcLevDistance' { 
        cpus = 1
        memory = { 8.GB * Math.pow(2, task.attempt - 1) }  // 8GB → 16GB → 32GB
        queue = 'medium'
        time = '1 day'
        maxForks = 20
    }

    withName: 'parseBlastOut' {
        cpus = 1
        memory = { 16.GB * Math.pow(2, task.attempt - 1) }  // 16GB → 32GB → 64GB
        queue = 'medium'
        time = { 4.hour * task.attempt }
    }

    withName: 'extractUniqQueryIndex' {
        cpus = 1
        memory = { 16.GB * Math.pow(2, task.attempt - 1) }
        queue = 'medium'
        time = { 4.hour * task.attempt }
    }

    withName: 'parseBestDemulti' { 
        cpus = 1
        memory = { 10.GB * Math.pow(2, task.attempt - 1) }
        queue = { task.attempt > 1 ? 'medium' : 'fast' }
        time = { 2.hour * task.attempt }
        maxForks = 50
    }
}