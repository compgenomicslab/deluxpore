manifest {
    author = 'Catalina Arnaiz'
    name = 'nxf-demultiplex'
    description = 'Nanopore-Illumina library based demultiplexing pipeline derived from Claudia Sanchis intial pipeline'
    homePage = 'https://github.com/ktlina/nextflow_demultiplex'
    mainScript = 'main.nf'
    nextflowVersion = '24.04.4'
}


params {
    
    /* Input and output options */
    projectName = null
    inputType = "raw"               // either raw or trimmed (for pre-processed reads)
    readsDir = null                 // reads dir with custom file extension *r{1,2}.fq.gz
    readsFileExtension = null
       
    quality_files = null            // if inputType is trimmed, path to quality json files - mandatory
    quality_file_extension = null   // if inputType is trimmed, quality json file extension excluding sample name

    outDir = null                   // path to output directory
    
    technology = null               // either shotgun or capture
    kit = null                      // when technology = capture, capture kit used: either phylokit, symbiokit or nitrokit
    grouping = null                 // when grouping = true, pre-assembly grouping strategy will be used

    /*Flags to make each step optional*/
    run_fastqc = true
    run_fastp = true
    run_multiqc = true
    run_motus = true
    run_motus_custom = false
    run_megahit = true
    run_metaquast_megahit = true
    run_metaspades = true
    run_metaquast_metaspades = true
    run_prodigal = true
    run_emapper = true


    /* FastP quality and trimming options */
    length_required = null
    dedup = false
    dup_calc_accuracy = null
    overrepresentation_analysis = false

    /* mOTUs options */
    motus_db = null                     // when run_motus_custom is true, give path to alternative database

    /* Groupin options */
    phylokit_db = "/home/acatalina/PHD/run_nextflow_hpc/nextflow_metag/assets/formatted_MG_seqs.faa.dmnd"

    /* Assembly options */


    /* Prodigal options */
    prodigal_format = null


    /* EggNOG mapper options */
    run_emapper = true                  // run eggNOG (database required)
    eggnog_db = "/data/jhc/ARCHIVE_data_jhc/soft/eggnog-mapper-dbs"                  
    eggnog_dbmem = false               // store the eggNOG sqlite DB into memory (~44GB memory required). This increases the annotation speed.



}


profiles {

    local {
        conda {
            enabled = true
        }
        executor {
            name = "local"
            cpus = 16
        }
        includeConfig 'config/local.config'
    }

    slurm {
        conda {
            enabled = true
        }
        executor {
            name = "slurm"
            queueSize = 200
        }
        includeConfig 'config/slurm.config'
    }
}