/* ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    ktlina/demultiplexer Nextflow config file
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Default config options for all compute environments
----------------------------------------------------------------------------------------
*/

manifest {
    author = 'Catalina Arnaiz'
    name = 'deluxepore'
    description = 'Nanopore-Illumina library based demultiplexing pipeline'
    homePage = 'https://github.com/ktlina/deluxpore'
    mainScript = 'main.nf'
    nextflowVersion = '>=23.04.0'
    version = '1.0.0'
}

params {
    /* Input and output options */
    projectName = null
    readsDir = null
    readsFileExtension = null
    experimentalDesign = null
    outDir = './results'

    /* Nanopore trimming and filtering options */
    trimandfilterNanopore = false
    nanoQscore = 20
    nanoLength = 100

    /* Illumina indexes trimming options */
    trimmIlluminaIndexes = false

    /* Illumina index seqs used for library construction */
    libraryIndexSeqs = null

    /* Resource limits - auto-detect by default */
    max_cpus = Runtime.runtime.availableProcessors()
    max_memory = '16 GB'

    /* Conda environment - null uses environment.yml, or provide path to pre-built env */
    conda_env = null

    help = false
    version = false
}

/* 
----------------------------------------------------------------------------------------
    Base process configuration
----------------------------------------------------------------------------------------
*/

process {
    cpus = { Math.min(task.cpus ?: 1, params.max_cpus as int) }
    memory = { 
        def requested = task.memory ?: 4.GB
        def maxMem = params.max_memory as nextflow.util.MemoryUnit
        return requested > maxMem ? maxMem : requested
    }
    errorStrategy = { task.exitStatus in [137, 140] ? 'retry' : 'finish' }
    maxRetries = 3

    conda = params.conda_env ?: "${projectDir}/envs/deluxpore.yml"
}

/* 
----------------------------------------------------------------------------------------
    Profiles
----------------------------------------------------------------------------------------
*/

profiles {

    conda {
        conda.enabled = true
        conda.useMamba = true
        conda.cacheDir = "${HOME}/.nextflow_conda"
    }

    local {
        process.beforeScript = 'eval "$(conda shell.bash hook)"'
        includeConfig 'config/local.config'
    }

    slurm {
        process.beforeScript = 'eval "$(conda shell.bash hook)"'
        params.max_memory = '128 GB'
        params.max_cpus = 32
        includeConfig 'config/slurm.config'
    }
}